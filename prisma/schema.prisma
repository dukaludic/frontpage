generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Feed {
  id         String     @id @default(uuid())
  url        String     @unique
  name       String
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  feed_items FeedItem[]

  @@map("feeds")
}

model FeedItem {
  id           String   @id @default(uuid())
  feed_id      String
  feed         Feed     @relation(fields: [feed_id], references: [id])
  url          String
  title        String
  description  String
  published_at DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("feed_items")
}
