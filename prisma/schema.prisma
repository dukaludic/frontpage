generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts  Account[]
  sessions  Session[]
  userFeeds UserFeed[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Feed {
  id              String     @id @default(uuid())
  url             String     @unique
  title           String?
  health_status   String?
  last_fetched_at DateTime?
  last_error      String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  feed_items      FeedItem[]
  userFeeds       UserFeed[]

  @@map("feeds")
}

model FeedItem {
  id           String   @id @default(uuid())
  feed_id      String
  feed         Feed     @relation(fields: [feed_id], references: [id])
  title        String?
  url          String
  description  String?
  published_at DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([feed_id, url])
  @@map("feed_items")
}

model UserFeed {
  userId String
  feedId String

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  customTitle String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed Feed @relation(fields: [feedId], references: [id], onDelete: Restrict)

  @@id([userId, feedId])
  @@map("users_feeds")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  userFeeds UserFeed[]

  @@map("categories")
}
